{
    "name": "applications",
    "primary_key_column": "id",
    "enable_rls": true,
    "visibility": "POD",
    "columns": [{
            "name": "company",
            "type": "TEXT",
            "required": true,
            "max_length": 200
        },
        {
            "name": "role",
            "type": "TEXT",
            "required": true,
            "max_length": 200
        },
        {
            "name": "job_description",
            "type": "TEXT",
            "required": true,
            "max_length": 15000
        },
        {
            "name": "fit_score",
            "type": "FLOAT",
            "required": false
        },
        {
            "name": "status",
            "type": "ENUM",
            "required": true,
            "default": "tailored",
            "options": [
                "tailored",
                "applied",
                "follow_up",
                "interview",
                "offer",
                "rejected"
            ]
        },
        {
            "name": "deadline",
            "type": "DATE",
            "required": false
        },
        {
            "name": "resume_version",
            "type": "TEXT",
            "required": false,
            "max_length": 200
        },
        {
            "name": "contact_name",
            "type": "TEXT",
            "required": false,
            "max_length": 200
        },
        {
            "name": "dm_status",
            "type": "ENUM",
            "required": false,
            "default": "draft",
            "options": [
                "draft",
                "approved",
                "sent"
            ]
        },
        {
            "name": "notes",
            "type": "TEXT",
            "required": false,
            "max_length": 3000
        }
    ],
    "config": {}
}